{
    "hosting": {
        "public": ".output/public",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "cleanUrls": true,
        "trailingSlash": false,
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "**",
                "headers": [
                    { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
                    { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
                ]
            }
        ]
    }
}
